<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8"/>
		<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
		<title>Distribution Center</title>
		<!-- Vue -->
		 <script src="https://unpkg.com/vue@3/dist/vue.global.js"></script>
		<!-- Axios -->
		 <script src="https://cdnjs.cloudflare.com/ajax/libs/axios/1.7.5/axios.min.js" integrity="sha512-01Pe9P3mJM/4c80VuoYEGHlspKGbd9uWQe9HtdLsdTqV0CS1kz8ca44sinVEXEvlZNciMmsAjeEbm5ZxHC7yYg==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
		<!-- Tailwind -->
		 <script src="https://cdn.tailwindcss.com"></script>
		<!-- Ripple Effect -->
		 <script src="https://cdn.jsdelivr.net/npm/@material/ripple@14.0.0/dist/mdc.ripple.min.js"></script>
		<link
		href="https://cdn.jsdelivr.net/npm/@material/ripple@14.0.0/dist/mdc.ripple.min.css" rel="stylesheet"/> <!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link
		href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap" rel="stylesheet">
		<!-- Toast -->
		<link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
		<link rel="stylesheet" type="text/css" href="/admin/view/stylesheet/dts.css">
	</head>

	<body class="bg-slate-300">
		<div id="app">
			<Layout class="w-screen h-screen" :tabs="tabs" :active-tab="activeTab" :loading="loading" :checked-orders="checkedOrders" :toggle-filter="toggleFilter" :has-filter="hasFilter" :logout="getRoute('common/logout', {}, true)" :hide-check-all="true" :side-menus="sideMenus" :ro-count="totalRevert" :ro-url="getRoute('revertOrders')" :home-url="getRoute()" :hide-clear-filter="hideClearFilter" name="Distribution Center" bulk-label="Generate DO" @clear-filter="clearFilter" @check-all="(checked) => checkedOrders = checked ? orders : []">
				<template v-if="activeTab == 'New'">
					<div class="flex flex-col gap-1 pt-1">
						<SecondTab v-for="deliveryZone in deliveryZones" :key="deliveryZone.delivery_zone_id" :title="deliveryZone.name" :active="selectedZone?.delivery_zone_id == deliveryZone.delivery_zone_id" :total="deliveryZone.total" @click-tab="toggleDeliveryZone(deliveryZone, true)">
							<template v-slot:orders>
								<DcOrder v-if="!loading" v-for="(customer, i) in customerOrders" :key="customer.customer_id" :customer="customer" :index="i" :order-url="getRoute('updateOrder')" :product-url="getRoute('updateProduct')" @submit="(customer) => showSubmit(customer)"></DcOrder>
								<!-- Submit All -->
								<Btn v-if="!loading && customerOrders.length" type="success" width="w-full" class="mt-3 bg-emerald-600" @click="showSubmitAll()">
									<div class="flex justify-center items-center gap-2">
										<p>Submit
											<span v-html="deliveryZone.name"></span>
										</p>
										<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewbox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
											<path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 0 0-10.026 0 1.106 1.106 0 0 0-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12"/>
										</svg>
									</div>
								</Btn>
								<!-- No Data -->
								<Nodata v-if="!loading && customerOrders.length == 0"></Nodata>
							</template>
						</SecondTab>
						<!-- No Zones -->
						<Nodata v-if="!loading && deliveryZones.length == 0"></Nodata>
					</div>
				</template>

				<!-- Ready to ship -->
				{# <template v-if="activeTab == 'Ready To Ship'">
													<div class="flex flex-col gap-3 p-2">
														<Order
															v-for="order in orders" 
															:key="order.order_id" 
															:order="order" 
															:products="order.products" 
															:checked-orders="checkedOrders" 
															:hide-button="true" 
															:menus="menus" 
															:updated-by="order.updated_by"
															:hide-checkbox="true"
															@checked="(checked) => handleOnCheck(checked, order)" 
															@click.stop="toggleOrder(order)"
														>
															<!-- Driver -->
															<template v-slot:info>
																<DriverInfo :delivery-zone="order.delivery_zone" :driver="order.driver" :phone="order.driver_phone"></DriverInfo>
															</template>
														</Order>
													</div>
													<Nodata v-if="orders.length == 0"></Nodata>
													<Btn @click="loadMore" v-else-if="orders.length != tabs[1].total" type="outline" class="mx-auto">Load More ...</Btn>
												</template> #}

				<!-- Pickup -->
					<template v-if="activeTab == 'Pickup'"> <div class="flex flex-col gap-3 p-2">
						<Order
							v-for="order in orders" :key="order.order_id" :order="order" :products="order.products" :checked-orders="checkedOrders" :hide-button="true" :show-do="true" :status="order.order_status" :updated-by="order.updated_by" :hide-checkbox="true" @checked="(checked) => handleOnCheck(checked, order)" @click.stop="toggleOrder(order)">
							<!-- Driver -->
							<template v-slot:info>
								<DriverInfo :delivery-zone="order.delivery_zone" :driver="order.driver" :phone="order.driver_phone"></DriverInfo>
							</template>
							<!-- Revert -->
							<template v-slot:buttons>
								<Btn v-if="order.can_revert" @click.stop="showRevert(order)" type="outline-warning" class="flex gap-2 px-7">
									<span>Revert</span>
									<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewbox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-5">
										<path stroke-linecap="round" stroke-linejoin="round" d="M9 15 3 9m0 0 6-6M3 9h12a6 6 0 0 1 0 12h-3"/>
									</svg>
								</Btn>
							</template>
						</Order>
						<Nodata v-if="orders.length == 0"></Nodata>
						<Btn @click="loadMore" v-else-if="orders.length != totalPickup" type="outline" class="mx-auto">Load More ...</Btn>
					</div>
				</template>
			</Layout>

			<!-- Order modal -->
			<Transition>
				<OrderModal v-if="showOrder" :order="selectedOrder" :products="selectedOrder?.products" :show-update="true" :hide-button="true" :show-final-qty="true" :disable-final-qty="true" :hide-out-of-stock="true" @cancel="toggleOrder(null)"></OrderModal>
			</Transition>

			<!-- Filter modal -->
			<Transition>
				<FilterModal v-if="showFilter" :filter-data="filterData" @close="toggleFilter(false)" @apply="handleFilter"></FilterModal>
			</Transition>

			<!-- Confirm Modal -->
			<ConfirmModal ref="confirmModal" :action="confirmAction"></ConfirmModal>
		</div>

		 <script>window.appConfig = {base_url: "{{ base_url }}"};</script>

		 <script type="module" src="{{ src }}"></script>
		 <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
		 <script type="text/javascript" src="https://cdn.jsdelivr.net/jquery/latest/jquery.min.js"></script>
		 <script type="text/javascript" src="https://cdn.jsdelivr.net/momentjs/latest/moment.min.js"></script>
		 <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/daterangepicker/daterangepicker.min.js"></script>
	<link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/daterangepicker/daterangepicker.css"/> </body>
</html>
