<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8"/>
		<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
		<title>Processing Department</title>
		<!-- Vue -->
    <script src="https://unpkg.com/vue@3/dist/vue.global.js"></script>
		<!-- Axios -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/axios/1.7.5/axios.min.js" integrity="sha512-01Pe9P3mJM/4c80VuoYEGHlspKGbd9uWQe9HtdLsdTqV0CS1kz8ca44sinVEXEvlZNciMmsAjeEbm5ZxHC7yYg==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
		<!-- Tailwind -->
		 <script src="https://cdn.tailwindcss.com"></script>
		<!-- Ripple Effect -->
		 <script src="https://cdn.jsdelivr.net/npm/@material/ripple@14.0.0/dist/mdc.ripple.min.js"></script>
		<link href="https://cdn.jsdelivr.net/npm/@material/ripple@14.0.0/dist/mdc.ripple.min.css" rel="stylesheet"/> <!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap" rel="stylesheet">
    <!-- Toast -->
    <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
	</head>

	<body class="bg-slate-300">
		<div id="app">
      <Layout
        :tabs="tabs" 
        :active-tab="activeTab" 
        :loading="loading" 
        :checked-orders="unselectOrders" 
        :toggle-filter="toggleFilter"
        :name="'{{ warehouse['name'] }}'"
        :bulk-label="bulkLabel"
        :has-filter="hasFilter"
        :logout="getRoute('common/logout', {}, true)"
        :ro="ordersRevert"
        :ro-count="totalRevert"
        :ro-url="getRoute('revertOrders')"
        :side-menus="sideMenus"
        :home-url="getRoute()"
        @check-all="handleCheckAll"
        @bulk-action="bulkAction"
        @clear-filter="clearFilter"
      >
        <!-- New -->
        <template v-if="activeTab == 'New'">
          <div class="flex flex-col gap-1">
            <!-- Today -->
            <SecondTab 
              title="Main Orders"
              :active="showToday"
              :total="totalToday"
              @click-tab="toggleTodayOrders(!showToday)"
            >
              <template v-if="showToday" v-slot:orders>
                <Order 
                  v-for="order in ordersToday" 
                  :type="order.urgent && 'primary'"
                  :key="order.order_id" 
                  :order="order"
                  :products="order.products"
                  :checked-orders="checkedOrders"
                  @checked="handleOnCheck"
                  @confirm="toggleConfirm(true, order)"
                  @click="toggleOrder(order)"
                >
                </Order>
                <Nodata v-if="showToday && !ordersToday.length"></Nodata>
                <Btn 
                  v-else-if="showToday && totalToday != ordersToday.length && !hasFilter"
                  @click="loadMore" 
                  type="outline" 
                  class="mx-auto"
                >
                  Load More ...
                </Btn>
              </template>
            </SecondTab>

            <!-- Advance -->
            <SecondTab 
              title="Advance"
              :active="showOthers"
              :total="totalOther"
              @click-tab="toggleOtherOrders(!showOthers)"
            >
              <template v-if="showOthers" v-slot:orders>
                <Order 
                  v-for="order in ordersOther" 
                  :key="order.order_id" 
                  :order="order"
                  :products="order.products"
                  :checked-orders="checkedOrders"
                  @checked="handleOnCheck"
                  @confirm="toggleConfirm(true, order)"
                  @click="toggleOrder(order)"
                ></Order>
                <Nodata v-if="showOthers && ordersOther.length == 0"></Nodata>
                <Btn 
                  v-else-if="showOthers && totalOther != ordersOther.length && !hasFilter"
                  @click="loadMore" 
                  type="outline" 
                  class="mx-auto"
                >
                  Load More ...
                </Btn>
              </template>
            </SecondTab>
          </div>
        </template>

        <!-- Processing -->
        <template v-if="activeTab == 'Processing'">
          <div class="w-full px-2 flex flex-col gap-4 ">
            <Batch
              v-for="batch in ordersProcessing" 
              :key="batch.warehouse_order_batch_id" 
              :batch="batch"
              :batch-url="getRoute('batch', {batch_id: batch.warehouse_order_batch_id})"
              :checked="checkedBatchs.some(b => b.warehouse_order_batch_id == batch.warehouse_order_batch_id)"
              :hide-button="true"
              @checked="handleBatchOnCheck"
              @pick="handlePick(batch)"
              @redirect="loading = true"
            ></Batch>
            <Nodata v-if="ordersProcessing.length == 0"></Nodata>
          </div>
        </template>

        <!-- Completed -->
        <template v-if="activeTab == 'Completed'">
          <!-- Tasks -->
          <div class="w-full px-2 flex flex-col gap-4 mb-10">
            <Order 
              v-for="order in ordersCompleted" 
              :key="order.order_id" 
              :order="order"
              :products="order.products"
              :hide-checkbox="true"
              :hide-button="true"
              :updated-by="order.updated_by"
              @checked="handleOnCheck"
              @confirm="toggleConfirm(true, order)"
              @click="toggleOrder(order)"
            >
              <template v-slot:buttons>
                <button v-if="order.can_revert" @click.stop="revert(order)" class="mdc-ripple-surface bg-yellow-500 border-yellow-300 border-2 px-7 py-1 rounded-md flex gap-2 text-white font-medium">
                  <span>Revert</span>
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 15 3 9m0 0 6-6M3 9h12a6 6 0 0 1 0 12h-3" />
                  </svg>
                </button>
              </template>
            </Order>
            <Nodata v-if="ordersCompleted.length == 0"></Nodata>
            <Btn 
              v-else-if="totalCompleted != ordersCompleted.length && !hasFilter"
              @click="loadMore" 
              type="outline" 
              class="mx-auto"
            >Load More ...</Btn>
          </div>
        </template>      
      </Layout>

      <!-- Loading modal -->
      <Transition>
        <Loading v-if="loading"></Loading>
      </Transition>

      <!-- Filter modal -->
      <Transition>
        <FilterModal 
          v-if="showFilter" 
          :filter-data="filterData"
          @close="showFilter = false"
          @apply="filter"
        ></FilterModal>
      </Transition>
      
      <!-- Confirm modal -->
      <Transition>
        <ConfirmProcessModal 
          v-if="showConfirm"
          :orders="checkedOrders"
          @pic-changed="(value) => pic = value"
          @close="toggleConfirm(false)"
          @reason-selected="(key) => handleCancelReason(key)"
          @input-quantity="(value) => remainingQuantity = value"
          @confirm="markProcessing()"
        ></ConfirmProcessModal>
      </Transition>
      
      <!-- Order modal -->
      <Transition>
        <OrderModal 
          v-if="showOrder"
          :order="selectedOrder"
          :products="getProducts(selectedOrder)"
          :toggle-confirm="toggleConfirm"
          :show-warehouse-qty="activeTab != 'New' ? true : false"
          :disable-warehouse-qty="activeTab == 'Processing' ? false : true"
          :disable-update="activeTab == 'Completed'"
          :hide-button="true"
          @cancel="toggleOrder(null)"
          @confirm="markProcessing()"
        ></OrderModal>
      </Transition>

      <!-- Picklist modal -->
      <Transition>
        <PicklistModal 
          v-if="showPicklist"
          :picklist="selectedPicklist"
          :saved-picklists="savedPicklists"
          @checked="handlePicklistChecked"
          @close="handlePicklistClose"
        ></PicklistModal>
      </Transition>

      
      <!-- Confirm generate picklist -->
      <Transition>
        <ConfirmPicklistModal 
          v-if="showConfirmPicklist"
          :batches="checkedBatchs"
          @confirm="generatePicklist()"
          @close="toggleConfirmPicklist(false)"
        ></ConfirmPicklistModal>
      </Transition>

      <!-- Complete order modal -->
      <Transition>
        <CompleteOrderModal 
          v-if="showCompleteOrder"
          :order="selectedOrder"
          @confirm="(order) => completeOrder(order)"
          @close="toggleComplete(false)"
        ></CompleteOrderModal>
      </Transition>
		</div>
	</body>

  <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
  <script type="text/javascript" src="https://cdn.jsdelivr.net/jquery/latest/jquery.min.js"></script>
  <script type="text/javascript" src="https://cdn.jsdelivr.net/momentjs/latest/moment.min.js"></script>
  <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/daterangepicker/daterangepicker.min.js"></script>
  <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/daterangepicker/daterangepicker.css" />
  <link rel="stylesheet" type="text/css" href="/admin/view/stylesheet/dts.css">
  
  <script>
    window.appConfig = {
      base_url: "{{ base_url }}",
      dir_image: "{{ dir_image }}",
    };
  </script>
  
  <script type="module">
    import Layout from '{{ base_url }}/extension/module/layout/main.js';
    import Secondtab from '{{ base_url }}/extension/module/components/second_tab.js';
    import Loading from '{{ base_url }}/extension/module/components/loading.js';
    import Order from '{{ base_url }}/extension/module/components/order.js';
    import Titlemenu from '{{ base_url }}/extension/module/components/title_menu.js';
    import Confirmprocessmodal from '{{ base_url }}/extension/module/components/confirm_process_modal.js';
    import Ordermodal from '{{ base_url }}/extension/module/components/order_modal.js';
    import Picklistmodal from '{{ base_url }}/extension/module/components/picklist_modal.js';
    import Completeordermodal from '{{ base_url }}/extension/module/components/complete_order_modal.js';
    import Filtermodal from '{{ base_url }}/extension/module/components/filter_modal.js';
    import Picklist from '{{ base_url }}/extension/module/components/picklist.js';
    import Batch from '{{ base_url }}/extension/module/components/batch.js';
    import Confirmpicklistmodal from '{{ base_url }}/extension/module/components/confirm_picklist_modal.js';
    import Btn from '{{ base_url }}/extension/module/components/btn.js';
    import Nodata from '{{ base_url }}/extension/module/components/no_data.js';

    const { createApp, ref, onMounted, defineComponent, computed } = Vue;

    createApp({
      components: {
        Layout,
        Secondtab,
        Loading, 
        Order, 
        Titlemenu, 
        Confirmprocessmodal, 
        Ordermodal,
        Picklistmodal,
        Completeordermodal,
        Filtermodal,
        Picklist,
        Batch,
        Confirmpicklistmodal,
        Btn,
        Nodata,
      },
      setup() {
        const limit = ref(10);
        const page = ref(1);

        const status = ref('new');
        const showToday = ref(true);  
        const showOthers = ref(false);  

        const showFilter = ref(false);

        const checkedOrders = ref([]);
        const checkedBatchs = ref([]);

        const loading = ref(false);
        const ordersToday = ref([]);
        const ordersOther = ref([]);
        const ordersRevert = ref([]);
        const ordersProcessing = ref([]);
        const ordersCompleted = ref([]);

        const selectedOrder = ref(null);
        const activeTab = ref("New");

        const showConfirm = ref(false);
        const showOrder = ref(false);

        const totalRevert = ref(0);
        const totalOther = ref(0);
        const totalProcessing = ref(0);
        const totalCompleted = ref(0);
        const totalToday = ref(0);
        const totalOverdue = ref(0);

        const showInProgress = ref(false);
        
        const showPicklistData = ref(false);
        const showPicklist = ref(false);
        const selectedPicklist = ref(false);
        
        const confirmAction = ref(null);
        const cancelReason = ref(null);
        const remainingQuantity = ref(null);

        const showConfirmPicklist = ref(false);
        const picklists = ref([]);
        const savedPicklists = ref([]);

        const showCompleteOrder = ref(false);
        const pic = ref(null);

        const tabs = ref([
          { 
            label: "New", 
            event: () => {
              if (activeTab.value == 'New') return ;
              activeTab.value = "New"
              fetch('main');
            },
            total: 0,
          },
          { 
            label: "Processing", 
            event: () => {
              if (activeTab.value == 'Processing') return ;
              activeTab.value = "Processing"
              fetch('processing');
            },
            total: 0,
          },
          { 
            label: "Completed", 
            event: () => {
              if (activeTab.value == 'Completed') return ;
              activeTab.value = "Completed"
              fetch('completed');
            },
            total: 0,
          },
        ]);

        const sideMenus = computed(() => {
          return [
            {
              label: 'Home',
              event: () => {
                window.location.href = getRoute('extension/module/processing_department', {}, true);
              },
              icon: "<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='currentColor' class='size-8'><path d='M11.47 3.841a.75.75 0 0 1 1.06 0l8.69 8.69a.75.75 0 1 0 1.06-1.061l-8.689-8.69a2.25 2.25 0 0 0-3.182 0l-8.69 8.69a.75.75 0 1 0 1.061 1.06l8.69-8.689Z' /><path d='m12 5.432 8.159 8.159c.03.03.06.058.091.086v6.198c0 1.035-.84 1.875-1.875 1.875H15a.75.75 0 0 1-.75-.75v-4.5a.75.75 0 0 0-.75-.75h-3a.75.75 0 0 0-.75.75V21a.75.75 0 0 1-.75.75H5.625a1.875 1.875 0 0 1-1.875-1.875v-6.198a2.29 2.29 0 0 0 .091-.086L12 5.432Z' /></svg>",
            },
            {
              label: 'Overdue Orders',
              event: () => {
                window.location.href = getRoute('overdue');
              },
              icon: "<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='currentColor' class='size-8'><path fill-rule='evenodd' d='M9.401 3.003c1.155-2 4.043-2 5.197 0l7.355 12.748c1.154 2-.29 4.5-2.599 4.5H4.645c-2.309 0-3.752-2.5-2.598-4.5L9.4 3.003ZM12 8.25a.75.75 0 0 1 .75.75v3.75a.75.75 0 0 1-1.5 0V9a.75.75 0 0 1 .75-.75Zm0 8.25a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Z' clip-rule='evenodd'/></svg>",
              total: totalOverdue.value,
            },
            {
              label: 'Revert Orders',
              event: () => {
                window.location.href = getRoute('revertOrders');
              },
              icon: "<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='currentColor' class='size-8'><path fill-rule='evenodd' d='M5.625 1.5H9a3.75 3.75 0 0 1 3.75 3.75v1.875c0 1.036.84 1.875 1.875 1.875H16.5a3.75 3.75 0 0 1 3.75 3.75v7.875c0 1.035-.84 1.875-1.875 1.875H5.625a1.875 1.875 0 0 1-1.875-1.875V3.375c0-1.036.84-1.875 1.875-1.875Zm5.845 17.03a.75.75 0 0 0 1.06 0l3-3a.75.75 0 1 0-1.06-1.06l-1.72 1.72V12a.75.75 0 0 0-1.5 0v4.19l-1.72-1.72a.75.75 0 0 0-1.06 1.06l3 3Z' clip-rule='evenodd'/><path d='M14.25 5.25a5.23 5.23 0 0 0-1.279-3.434 9.768 9.768 0 0 1 6.963 6.963A5.23 5.23 0 0 0 16.5 7.5h-1.875a.375.375 0 0 1-.375-.375V5.25Z'/></svg>",
              total: totalRevert.value,
            },
          ];
        });

        const toast = (message, type='success') => {
          let background = '#16a34a';
          if (type == 'error') {
            background = '#de2837';
          }
          Toastify({
            text: message,
            duration: 3000,
            close: true,
            gravity: "top", // `top` or `bottom`
            position: "right", // `left`, `center` or `right`
            stopOnFocus: true, 
            style: {
              background,
            },
          }).showToast();
        }

        const unselectOrders = computed(() => {
          if (activeTab.value == 'New') {
            return checkedOrders.value;
          } else if (activeTab.value == 'Processing') {
            return checkedBatchs.value;
          }
          return checkedOrders.value;
        })
        
        const unselect = () => {
          if (activeTab.value == 'New') {
            return checkedOrders.value = [];
          } else if (activeTab.value == 'Processing') {
            return checkedBatchs.value = [];
          }
        }

        const toggleTodayOrders = (value=true) => {        
          if (value) {
            fetch('main', true);
          }
          if (value && showOthers.value) {
            showOthers.value = false;
          }
          showToday.value = value;
        } 

        const toggleOtherOrders = (value=true) => {
          if (value) {
            fetch('advance', true);
          }
          if (value && showToday.value) {
            showToday.value = false
          }
          showOthers.value = value
        } 

        const cancelReasonsData = ref([
          {label: 'Out of Stock', key: 'out-of-stock'},
          {label: 'With Remaining Stock', key: 'with-remaining-stock'},
        ]);

        const toggleConfirm = (value=true, order=null) => {
          showConfirm.value = value;
          if (checkedOrders.value.length == 0 && order) {
            checkedOrders.value = [order]
          }
        }

        const getProducts = (order) => order.show_more ? order.products : order.products.slice(0, 1)

        const getProductsByBatch = (batch) => {
          return batch.warehouse_orders.flatMap(order => order.products)
        }

        const handleCancelReason = (key) => {
          cancelReason.value = key;
        }

        const toggleOrder = (order=null) => {
          selectedOrder.value = order;
          showOrder.value = order != null ? true : false;
        }

        const toggleComplete = (value, order=null) => {
          if (order) {
            selectedOrder.value = order
          }
          showCompleteOrder.value = value;
        }

        // Get base API route
        const getRoute = (route='', filters={}, base=false) => {
          let filter = '';
          for (const [key, value] of Object.entries(filters)) {
            filter += `&${encodeURIComponent(key)}=${encodeURIComponent(value)}`;
          }
          
          if (route == '') {
            return '/admin/index.php?route=extension/module/processing_department&user_token={{ user_token }}' + filter;
          }

          let url = '';
          if (base) {
            url = `/admin/index.php?route=${route}&user_token={{ user_token }}` + filter;
          } else {
            url = `/admin/index.php?route=extension/module/processing_department/${route}&user_token={{ user_token }}` + filter;
          }

          return url;
        }

        // Fetch orders
        const fetch = async (stats, reset = false) => {
          loading.value = true;

          checkedOrders.value = [];

          let tabChanged = status.value != stats;
          status.value = stats;
          if (tabChanged || reset) {
            ordersToday.value = [];
            ordersOther.value = [];
            ordersProcessing.value = [];
            ordersCompleted.value = [];

            page.value = 1;
          }

          axios.get(getRoute('orders'), {
            params: {
              status: status.value,
              ...filterData.value,
              page: page.value,
              limit: limit.value,
            },
          })
            .then(response => {
              const {orders, total} = response.data; 

              // Main
              if (status.value == 'main') {
                ordersToday.value = ordersToday.value.concat(orders);

              // Advance
              } else if (status.value == 'advance') {
                ordersOther.value = ordersOther.value.concat(orders);

              // Processing
              } else if (status.value == 'processing') {
                ordersProcessing.value = ordersProcessing.value.concat(orders);

              // Competed
              } else if (status.value == 'completed') {
                ordersCompleted.value = ordersCompleted.value.concat(orders);
              }

              // Revert Orders
              ordersRevert.value = orders;

              // Total
              tabs.value[0].total = parseFloat(total.today) + parseFloat(total.advance)
              tabs.value[1].total = parseFloat(total.processing)
              totalToday.value = total.today;
              totalOther.value = total.advance;
              totalProcessing.value = total.processing;
              totalCompleted.value = total.completed;
              totalRevert.value = total.revert;
              totalOverdue.value = total.overdue;
            })
            .catch(error => {
              toast(error, 'error');       
            })
            .finally(() => {
              loading.value = false
            })
        }

        // Mark order 'processing'
        const markProcessing = async () => {
          showOrder.value = false;
          loading.value = true;

          axios.post(getRoute('markProcessing'), {
            warehouse_order_ids: checkedOrders.value.map(x => x.warehouse_order_id),
            order_ids: checkedOrders.value.map(x => x.order_id),
          })
            .then((response) => {
              activeTab.value = 'Processing';
              fetch('processing');
              toast('Order marked as processing.');
            })
            .catch(error => {
              error.response.data.error 
                ? alert(error.response.data.error)
                : alert(error)
            })
            .finally(() => {
              toggleConfirm(false);
              loading.value = false
            })
        }

        // Get picklists
        const getPicklists = async () => {
          loading.value = true;
          const url = getRoute('getPicklist');
          await axios.get(url)
            .then(response => {
              savedPicklists.value = response.data
            })
            .catch(error => toast(error))
            .finally(() => loading.value = false)
        }

        // Generate picklist from batch
        const generatePicklist = async (batch=null) => {
          loading.value = true;

          if (batch) {
            checkedBatchs.value = [batch]
          }

          const products = checkedBatchs.value.map(batch => getProductsByBatch(batch)).flat()
          
          // Summarise quantity
          const picklist = products.reduce((acc, obj) => {
            const key = `${obj.product_id}-${obj.weight}-${obj.product_option_value_id}`;
            
            if (!acc[key]) {
              acc[key] = { ...obj };
              acc[key].quantity = parseInt(obj.quantity, 10);
            } else {
              acc[key].quantity += parseInt(obj.quantity, 10);
            }
            
            return acc;
          }, {});

          // Call db to create picklist
          const url = getRoute('savePicklist')
          await axios.post(url, {
            warehouse_order_batch_ids: checkedBatchs.value.map(b => b.warehouse_order_batch_id),
            picklist
          })
            .then(async (response) => {
              // Redirecct to batch page
              const first_batchid = checkedBatchs.value[0].warehouse_order_batch_id;
              window.location.href = getRoute('batch', {batch_id: first_batchid})              
            })
            .catch(error => console.error(error))
            .finally(() => {
              loading.value = false;
              toggleConfirmPicklist(false);
              toast('Picklist generated')
            })

          picklists.value = picklist;
        }

        // Show picklist data
        const togglePicklistData = () => {
          showPicklistData.value = !showPicklistData.value;

          if (showPicklistData.value && showInProgress.value) {
            showInProgress.value = false;
          }

          if (showPicklistData.value) getPicklists();
        }

        const toggleInProgress = () => {
          showInProgress.value = !showInProgress.value;

          if (showInProgress.value && showPicklistData.value) {
            showPicklistData.value = false;
          }

          if (showInProgress.value) {
            fetch('processing')
          }
        }

        const togglePicklist = (value, picklist) => {
          showPicklist.value = value;
          selectedPicklist.value = picklist;
        }

        const handleCheckAll = (checked) => {
          // Checked
          if (checked) {
            if (activeTab.value == 'New') {
              checkedOrders.value = showToday.value ? ordersToday.value : ordersOther.value;
            } else if (activeTab.value == 'Processing') {
              let to_check = ordersProcessing.value.filter(o => o.picklist_id == null)
              checkedBatchs.value = to_check;
            }

          // Uncheck
          } else {
            checkedOrders.value = [];
            checkedBatchs.value = [];
          }
        }

        const handlePicklistChecked = (checked, order_product_id) => {
          const keys = Object.keys(selectedPicklist.value.json);
          keys.forEach(key => {
            if (selectedPicklist.value.json[key].order_product_id == order_product_id) {
              selectedPicklist.value.json[key].checked = checked
            }
          })
        }

        const handlePicklistClose = async () => {
          loading.value = true;

          const url = getRoute('savePicklist')

          // Call db to update picklsit
          await axios.post(url, {
            picklist_id: selectedPicklist.value.picklist_id,
            picklist: selectedPicklist.value.json,
          })
            .catch(error => console.error(error))
            .finally(() => {
              loading.value = false;
              showPicklist.value = false;
              getPicklists();        
            })      
        }

        const handlePick = (batch) => {
          if (batch.picklist_id) {
            loading.value = true;
            window.location.href = getRoute('batch', {batch_id: batch.warehouse_order_batch_id});
          } else {
            toggleConfirmPicklist(true, batch);
          }
        }

        const completeOrder = async (order) => {
          const url = getRoute('completeOrder')
          loading.value = true;

          await axios.post(url, {order})
            .then(response => {
              fetch('processing');
              toast('Order has been completed');
            })
            .catch(error => console.error(error))
            .finally(() => {
              showCompleteOrder.value = false;
            })
        }

        const handleOnCheck = (checked, order) => {
          const warehouse_order_id = order;

          if (checked && !checkedOrders.value.find(x => x.warehouse_order_id == warehouse_order_id)) {
            checkedOrders.value.push(order);
          } else {
            const index = checkedOrders.value.findIndex(x => x.warehouse_order_id == warehouse_order_id);
            checkedOrders.value.splice(index, 1);
          }
        }

        const handleBatchOnCheck = (checked, batch) => {
          if (checked) {
            if (checkedBatchs.value.some(b => b.warehouse_order_batch_id == batch.warehouse_order_batch_id)) return;
            checkedBatchs.value.push(batch)
          } else {
            checkedBatchs.value = checkedBatchs.value.filter(b => b.warehouse_order_batch_id != batch.warehouse_order_batch_id)
          }     
        }

        const revert = async (order) => {
          const url = getRoute('revertOrder')
          loading.value = true;

          await axios.post(url, {warehouse_order_id: order.warehouse_order_id, order_id: order.order_id})
            .then(response => {
              activeTab.value = 'Processing';
              fetch('processing');
              toast('Order reverted.');
            })
            .catch(error => alert(error))
            .finally(() => {
              loading.value = false;
            })
        }

        const filterData = ref({
          customer: '',
          order_id: '',
          batch_id: '',
          delivery_date: '',
        })

        const toggleFilter = (value=true) => {
          showFilter.value = value;
        }
        
        const filter = (data) => {
          toggleFilter(false);
          fetch(status.value, true);
        }

        // Has apply filter
        const hasFilter = computed(() => {
          return Object.keys(filterData.value).some((key) => {
            const value = filterData.value[key];
            return value != '';
          })
        })

        // Clear filter
        const clearFilter = () => {
          for (const key in filterData.value) {
            if (filterData.value.hasOwnProperty(key)) {
              filterData.value[key] = ''; 
            }
          }
          fetch(status.value, true)
        }

        // Check all label
        const bulkLabel = computed(() => {
          if (activeTab.value == 'New') {
            return 'Process';
          } else if (activeTab.value == 'Processing') {
            return 'Pick';
          }
        })

        // Check all action
        const bulkAction = (orders) => {
          if (activeTab.value == 'New') {
            toggleConfirm(true);

          } else if (activeTab.value == 'Processing') {
            toggleConfirmPicklist(true);
          }
        }

        // Show confirm generate picklist
        const toggleConfirmPicklist = (value, batch=null) => {
          showConfirmPicklist.value = value;
          if (batch != null) {
            checkedBatchs.value = [batch];
          }
        }

        // Load more ...
        const loadMore = () => {
          page.value += 1;
          fetch(status.value);
        }

        // Mounted
        onMounted(() => {
          const params = new URLSearchParams(window.location.search);
          const redirect = params.get('redirect');

          // Redirect to completed
          if (redirect == 'completed') {
            activeTab.value = 'Completed';
            fetch('completed');

          } else if (redirect == 'processing') {
            activeTab.value = 'Processing';
            fetch('processing');

          // Default
          } else {
            toggleTodayOrders(true);
          }
          
          /** 
          const scrollContainer = document.getElementById('content'); // Select the scrollable div
          scrollContainer.addEventListener('scroll', function() {
            if (scrollContainer.scrollTop + scrollContainer.clientHeight >= scrollContainer.scrollHeight - 1) {
              loadMore();
            }
          });  
          */    
        })

        return {
          fetch,
          tabs,
          loading,
          showFilter,
          selectedOrder,
          toggleTodayOrders,
          toggleOtherOrders,
          activeTab,
          showConfirm,
          ordersToday,
          ordersOther,
          ordersCompleted,
          ordersProcessing,
          toggleConfirm,
          getProducts,
          getProductsByBatch,
          cancelReasonsData,
          cancelReason,
          handleCancelReason,
          confirmAction,
          remainingQuantity,
          toggleOrder,
          showOrder,
          showPicklist,
          markProcessing,
          generatePicklist,
          picklists,
          savedPicklists,
          handlePicklistClose,
          showCompleteOrder,
          toggleComplete,
          showToday,
          showOthers,
          checkedOrders,
          checkedBatchs,
          handleOnCheck,
          handleBatchOnCheck,
          pic,
          togglePicklist,
          selectedPicklist,
          handlePick,
          handlePicklistChecked,
          completeOrder,
          totalToday,
          totalOther,
          revert,
          togglePicklistData,
          showPicklistData,
          toggleInProgress,
          showInProgress,
          toggleFilter,
          filterData,
          filter,
          hasFilter,
          clearFilter,
          unselectOrders,
          unselect,
          handleCheckAll,
          bulkLabel,
          bulkAction,
          showConfirmPicklist,
          toggleConfirmPicklist,
          loadMore,
          totalProcessing,
          totalCompleted,
          ordersRevert,
          totalRevert,
          sideMenus,
          getRoute,
          totalOverdue,
        };
      },
    }).mount("#app");
    
  </script>

</html>
