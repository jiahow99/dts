{{ header }}{{ column_left }}
<div id="content">
	<div class="page-header">
		<div class="container-fluid">
			<h1>{{ heading_title }}</h1>
			<ul class="breadcrumb">
				{% for breadcrumb in breadcrumbs %}
					<li>
						<a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a>
					</li>
				{% endfor %}
			</ul>
		</div>
	</div>
	<div class="container-fluid">
		<div class="row">
			<div id="filter-review" class="col-md-3 col-md-push-9 col-sm-12 hidden-sm hidden-xs">
				<div class="panel panel-default">
					<div class="panel-heading">
						<h3 class="panel-title">
							<i class="fa fa-filter"></i>
							{{ text_filter }}</h3>
					</div>
					<div class="panel-body">
						<div class="form-group">
							<label class="control-label" for="input-delivery-date">{{ entry_delivery_date }}</label>
							<input type="date" name="filter_delivery_date" {% if filter_delivery_date != '' %}value="{{ filter_delivery_date }}"{% endif %}id="input-delivery_date" class="form-control date"/>
						</div>
						<div class="form-group text-right">
							<button type="button" id="button-filter" class="btn btn-default">
								<i class="fa fa-filter"></i>
								{{ button_filter }}</button>
						</div>
					</div>
				</div>
			</div>
			<div class="col-md-9 col-md-pull-3 col-sm-12">
				<div class="panel panel-default">
					<div class="panel-heading">
						<h3 class="panel-title">
							<i class="fa fa-list"></i>
							{{ text_list }}</h3>
					</div>
					<div class="panel-body">
						<form action="{{ delete }}" method="post" enctype="multipart/form-data" id="form-review">
							<div class="table-responsive">
								<table class="table table-bordered table-hover">
									<thead>
										<tr>
											<td style="width: 1px;" class="text-center"><input type="checkbox" onclick="$('input[name*=\'selected\']').prop('checked', this.checked);"/></td>
											<td class="text-left">
                        <span>{{ column_delivery_date }}</span>
											</td>
											<td class="text-left">
												<span>{{ column_total_orders }}</span>
											</td>
											<td class="text-left">
												<span>{{ column_without_driver }}</span>
											</td>
											<td class="text-center">{{ column_action }}</td>
										</tr>
									</thead>
									<tbody>

										{% if summaries %}
											{% for summary in summaries %}
												<tr>
													<td class="text-center">
														{% if summary.delivery_date in selected %}
															<input type="checkbox" name="selected[]" value="{{ summary.delivery_date }}" checked="checked"/>
														{% else %}
															<input type="checkbox" name="selected[]" value="{{ summary.delivery_date }}"/>
														{% endif %}
													</td>
													<td class="text-left">
														{{ summary.delivery_date }}
														{% if summary.is_today %}
															<span style="background-color: #10b981; font-weight: 700; font-size: 1rem; color: white; padding: 2px 10px; border-radius: 20px;">Today</span>
														{% endif %}
													</td>
													<td class="text-left">
														<span style="color: #10b981; font-weight: 700">{{ summary.total_delivered }}</span>
														/
														{{ summary.total_orders }}</td>
													{% if summary.total_without_driver > 0 %}
														<td class="text-left" style="color: #f59e0b; font-weight: 700">{{ summary.total_without_driver }}</td>
													{% else %}
														<td class="text-left">-</td>
													{% endif %}

													<td class="text-center">
														<a href="{{ summary.action }}" data-toggle="tooltip" title="{{ button_view }}" class="btn btn-primary">
															<i class="fa fa-eye"></i>
														</a>
													</td>
												</tr>
											{% endfor %}
										{% else %}
											<tr>
												<td class="text-center" colspan="7">{{ text_no_results }}</td>
											</tr>
										{% endif %}
									</tbody>

								</table>
							</div>
						</form>
						<div class="row">
							<div class="col-sm-6 text-left">{{ pagination }}</div>
							<div class="col-sm-6 text-right">{{ results }}</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
	 <script type="text/javascript"><!--
			$('#button-filter').on('click', function() {
				url = 'index.php?route=location/driver_admin&user_token={{ user_token }}';
				
				var filter_delivery_date = $('input[name=\'filter_delivery_date\']').val();
				if (filter_delivery_date) {
					url += '&filter_delivery_date=' + encodeURIComponent(filter_delivery_date);
				}

        location = url;
			});
	
			//--></script>
	 <script type="text/javascript"><!--

			//--></script>
</div>
{{ footer }}
